{
  "info": {
    "name": "Codefeast Assignment — Employee API",
    "description": "Full CRUD Employee API with salary calculation and aggregate metrics endpoints.\n\n**Base URL**: `http://localhost:3000`\n\n**Collection variable**: `baseUrl` → set to `http://localhost:3000`\n\nRun requests in the **Employees** folder top-to-bottom to create a record first, then use the auto-captured `employeeId` in subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "codefeast-employee-api-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "employeeId",
      "value": "1",
      "type": "string",
      "description": "Auto-set by the 'Create Employee' request's Tests script"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns server status and current timestamp."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/health" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\",\n  \"timestamp\": \"2026-05-03T06:00:00.000Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Create Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('employeeId', json.data.id);",
                  "  pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "  pm.test('success is true', () => pm.expect(json.success).to.be.true);",
                  "  pm.test('id is returned', () => pm.expect(json.data.id).to.be.a('number'));",
                  "  pm.test('jobTitle is returned', () => pm.expect(json.data.jobTitle).to.be.a('string'));",
                  "  pm.test('country is returned', () => pm.expect(json.data.country).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"jobTitle\": \"Software Engineer\",\n  \"country\": \"IN\",\n  \"salary\": 90000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "employees"]
            },
            "description": "Creates a new employee. Required fields: `name`, `email`, `jobTitle`, `country`, `salary`. Auto-saves the returned `id` as the `employeeId` collection variable."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/api/v1/employees" }
              },
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane.doe@example.com\",\n    \"jobTitle\": \"Software Engineer\",\n    \"country\": \"IN\",\n    \"salary\": 90000,\n    \"createdAt\": \"2026-05-03T06:00:00.000Z\",\n    \"updatedAt\": \"2026-05-03T06:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "400 Missing Field",
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/api/v1/employees" }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"jobTitle is required\"\n}"
            },
            {
              "name": "409 Duplicate Email",
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/api/v1/employees" }
              },
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"success\": false,\n  \"message\": \"email already exists\"\n}"
            }
          ]
        },
        {
          "name": "List All Employees",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success is true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('data is an array', () => pm.expect(json.data).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "employees"]
            },
            "description": "Returns all employees ordered by `createdAt` descending (newest first)."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/v1/employees" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"id\": 1,\n      \"name\": \"Jane Doe\",\n      \"email\": \"jane.doe@example.com\",\n      \"jobTitle\": \"Software Engineer\",\n      \"country\": \"IN\",\n      \"salary\": 90000,\n      \"createdAt\": \"2026-05-03T06:00:00.000Z\",\n      \"updatedAt\": \"2026-05-03T06:00:00.000Z\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Get Employee by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('correct employee returned', () => {",
                  "  pm.expect(json.data.id).to.equal(parseInt(pm.collectionVariables.get('employeeId')));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "employees", "{{employeeId}}"]
            },
            "description": "Fetches a single employee by ID."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/v1/employees/1" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane.doe@example.com\",\n    \"jobTitle\": \"Software Engineer\",\n    \"country\": \"IN\",\n    \"salary\": 90000\n  }\n}"
            },
            {
              "name": "404 Not Found",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/v1/employees/9999" }
              },
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Employee not found\"\n}"
            }
          ]
        },
        {
          "name": "Update Employee (partial)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('salary updated', () => pm.expect(json.data.salary).to.equal(95000));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": 95000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "employees", "{{employeeId}}"]
            },
            "description": "Partial update — only the fields included in the body are changed. Omitted fields are preserved. Updatable fields: `name`, `email`, `jobTitle`, `country`, `salary`."
          },
          "response": [
            {
              "name": "200 OK (salary updated)",
              "originalRequest": {
                "method": "PUT",
                "url": { "raw": "{{baseUrl}}/api/v1/employees/1" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane.doe@example.com\",\n    \"jobTitle\": \"Software Engineer\",\n    \"country\": \"IN\",\n    \"salary\": 95000\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Employee Salary — India (IN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.test('taxRate is 0.10 for IN', () => pm.expect(d.taxRate).to.equal(0.10));",
                  "pm.test('netSalary correct', () => pm.expect(d.netSalary).to.equal(d.grossSalary * 0.90));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/employees/{{employeeId}}/salary?country=IN",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "employees", "{{employeeId}}", "salary"],
              "query": [
                { "key": "country", "value": "IN", "description": "IN=10% | US=12% | other=0%" }
              ]
            },
            "description": "Returns the net salary breakdown for a given country's flat tax rate.\n\n| country | Tax rate |\n|---|---|\n| IN | 10% |\n| US | 12% |\n| any other | 0% (net = gross) |"
          },
          "response": [
