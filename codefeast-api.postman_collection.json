              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"employeeId\": 1,\n    \"grossSalary\": 95000,\n    \"country\": \"IN\",\n    \"taxRate\": 0.10,\n    \"taxAmount\": 9500,\n    \"netSalary\": 85500\n  }\n}"
            },
            {
              "name": "400 Missing country",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/v1/employees/1/salary" }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"country query parameter is required\"\n}"
            }
          ]
